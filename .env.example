# Copy to .env and fill real values. Do not commit .env.

# Keep runtime artifacts on the external disk when possible.
PERSONAL_NEWS_EXT_ROOT=/Volumes/ext
PERSONAL_NEWS_DB=sqlite:////Volumes/ext/personal_news_agent/personal_news.db

# Crawl URL queue/state backend. MySQL owns crawl URLs and refresh state;
# SQLite remains only a local development fallback for app metadata/articles.
PERSONAL_NEWS_CRAWL_URL_BACKEND=mysql
PERSONAL_NEWS_CRAWL_DB_URL=mysql+pymysql://user:password@host:3306/personal_news?charset=utf8mb4
PERSONAL_NEWS_CRAWL_INTERVAL_MINUTES=10
PERSONAL_NEWS_CRAWL_INTERVAL_MAX_MINUTES=20

# Elasticsearch owns article recall/search. If empty, the app falls back to
# SQLite FTS for local development.
PERSONAL_NEWS_SEARCH_BACKEND=elasticsearch
ELASTICSEARCH_URL=http://127.0.0.1:9200
PERSONAL_NEWS_ES_INDEX=personal_news_articles
PNA_HTTP_VERIFY_SSL=0

# Optional: stock_agent database connection for creating pna_* user tables.
# The current MVP runtime uses SQLite by default; use sql/pna_schema_mysql.sql
# against this database when deploying the user/profile tables into stock_agent.
PNA_USER_DB_URL=mysql+pymysql://user:password@host:3306/stock_agent?charset=utf8mb4

# OpenAI-compatible LLM endpoint.
PNA_LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
PNA_LLM_KEY=
PNA_LLM_DEFAULT_MODEL=yuanrong-personal-assistant
PNA_LLM_TIMEOUT_SECONDS=120

# WeChat official OAuth settings.
# WeChat is not part of the current registration flow; keep these empty unless
# you later re-enable WeChat login.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://127.0.0.1:8000/api/auth/wechat/callback
WECHAT_LOGIN_MODE=website

# Optional external search.
EXTERNAL_SEARCH_PROVIDER=none
BING_SEARCH_KEY=

# Real-name mobile verification.
# mock is for local demo only. Production should use aliyun or tencent after
# opening the corresponding official service.
PNA_REALNAME_PROVIDER=mock
PNA_REALNAME_MOCK_ENABLED=1
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
# Official Alibaba Cloud env names and the current local aliases are also supported:
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# AccessKeyID=
# AccessKeySecret=
ALIYUN_CLOUDAUTH_ENDPOINT=cloudauth.aliyuncs.com
ALIYUN_REGION_ID=cn-beijing
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
